<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="tech.qiantong.qdata.module.dm.dal.mapper.dm.DmDataLayerSpecificationMapper">

    <resultMap type="DmDataLayerSpecificationDO" id="DmDataLayerSpecificationResult">
        <result property="id"    column="ID"    />
        <result property="dataLayerId"    column="DATA_LAYER_ID"    />
        <result property="prefixName"    column="PREFIX_NAME"    />
        <result property="businessEngName"    column="BUSINESS_ENG_NAME"    />
        <result property="ownerUserId"    column="OWNER_USER_ID"    />
        <result property="status"    column="STATUS"    />
        <result property="description"    column="DESCRIPTION"    />
        <result property="validFlag"    column="VALID_FLAG"    />
        <result property="delFlag"    column="DEL_FLAG"    />
        <result property="createBy"    column="CREATE_BY"    />
        <result property="creatorId"    column="CREATOR_ID"    />
        <result property="createTime"    column="CREATE_TIME"    />
        <result property="updateBy"    column="UPDATE_BY"    />
        <result property="updaterId"    column="UPDATER_ID"    />
        <result property="updateTime"    column="UPDATE_TIME"    />
        <result property="remark"    column="REMARK"    />
    </resultMap>

    <sql id="selectDmDataLayerSpecificationVo">
        select ID, DATA_LAYER_ID, PREFIX_NAME, BUSINESS_ENG_NAME, OWNER_USER_ID, STATUS, DESCRIPTION, VALID_FLAG, DEL_FLAG, CREATE_BY, CREATOR_ID, CREATE_TIME, UPDATE_BY, UPDATER_ID, UPDATE_TIME, REMARK from DM_DATA_LAYER_SPECIFICATION
    </sql>

    <select id="selectDmDataLayerSpecificationList" parameterType="DmDataLayerSpecificationDO" resultMap="DmDataLayerSpecificationResult">
        <include refid="selectDmDataLayerSpecificationVo"/>
        <where>
            <if test="dataLayerId != null "> and DATA_LAYER_ID = #{dataLayerId}</if>
            <if test="prefixName != null  and prefixName != ''"> and PREFIX_NAME like concat('%', #{prefixName}, '%')</if>
            <if test="businessEngName != null  and businessEngName != ''"> and BUSINESS_ENG_NAME like concat('%', #{businessEngName}, '%')</if>
            <if test="ownerUserId != null "> and OWNER_USER_ID = #{ownerUserId}</if>
            <if test="status != null  and status != ''"> and STATUS = #{status}</if>
            <if test="description != null  and description != ''"> and DESCRIPTION like concat('%', #{description}, '%')</if>
            <if test="createTime != null "> and CREATE_TIME = #{createTime}</if>
        </where>
    </select>

    <select id="selectDmDataLayerSpecificationById" parameterType="Long" resultMap="DmDataLayerSpecificationResult">
        <include refid="selectDmDataLayerSpecificationVo"/>
        where ID = #{id}
    </select>

    <insert id="insertDmDataLayerSpecification" parameterType="DmDataLayerSpecificationDO">
        insert into DM_DATA_LAYER_SPECIFICATION
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">ID,</if>
            <if test="dataLayerId != null">DATA_LAYER_ID,</if>
            <if test="prefixName != null">PREFIX_NAME,</if>
            <if test="businessEngName != null">BUSINESS_ENG_NAME,</if>
            <if test="ownerUserId != null">OWNER_USER_ID,</if>
            <if test="status != null">STATUS,</if>
            <if test="description != null">DESCRIPTION,</if>
            <if test="validFlag != null">VALID_FLAG,</if>
            <if test="delFlag != null">DEL_FLAG,</if>
            <if test="createBy != null">CREATE_BY,</if>
            <if test="creatorId != null">CREATOR_ID,</if>
            <if test="createTime != null">CREATE_TIME,</if>
            <if test="updateBy != null">UPDATE_BY,</if>
            <if test="updaterId != null">UPDATER_ID,</if>
            <if test="updateTime != null">UPDATE_TIME,</if>
            <if test="remark != null">REMARK,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="dataLayerId != null">#{dataLayerId},</if>
            <if test="prefixName != null">#{prefixName},</if>
            <if test="businessEngName != null">#{businessEngName},</if>
            <if test="ownerUserId != null">#{ownerUserId},</if>
            <if test="status != null">#{status},</if>
            <if test="description != null">#{description},</if>
            <if test="validFlag != null">#{validFlag},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="creatorId != null">#{creatorId},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updaterId != null">#{updaterId},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateDmDataLayerSpecification" parameterType="DmDataLayerSpecificationDO">
        update DM_DATA_LAYER_SPECIFICATION
        <trim prefix="SET" suffixOverrides=",">
            <if test="dataLayerId != null">DATA_LAYER_ID = #{dataLayerId},</if>
            <if test="prefixName != null">PREFIX_NAME = #{prefixName},</if>
            <if test="businessEngName != null">BUSINESS_ENG_NAME = #{businessEngName},</if>
            <if test="ownerUserId != null">OWNER_USER_ID = #{ownerUserId},</if>
            <if test="status != null">STATUS = #{status},</if>
            <if test="description != null">DESCRIPTION = #{description},</if>
            <if test="validFlag != null">VALID_FLAG = #{validFlag},</if>
            <if test="delFlag != null">DEL_FLAG = #{delFlag},</if>
            <if test="createBy != null">CREATE_BY = #{createBy},</if>
            <if test="creatorId != null">CREATOR_ID = #{creatorId},</if>
            <if test="createTime != null">CREATE_TIME = #{createTime},</if>
            <if test="updateBy != null">UPDATE_BY = #{updateBy},</if>
            <if test="updaterId != null">UPDATER_ID = #{updaterId},</if>
            <if test="updateTime != null">UPDATE_TIME = #{updateTime},</if>
            <if test="remark != null">REMARK = #{remark},</if>
        </trim>
        where ID = #{id}
    </update>

    <delete id="deleteDmDataLayerSpecificationById" parameterType="Long">
        delete from DM_DATA_LAYER_SPECIFICATION where ID = #{id}
    </delete>

    <delete id="deleteDmDataLayerSpecificationByIds" parameterType="String">
        delete from DM_DATA_LAYER_SPECIFICATION where ID in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
