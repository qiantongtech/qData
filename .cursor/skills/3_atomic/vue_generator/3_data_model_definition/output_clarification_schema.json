{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PageSpecClarification",
  "description": "数据模型定义技能在缺表结构或字段不足时的澄清/推荐输出，非完整 page_spec",
  "type": "object",
  "required": ["clarificationNeeded", "reason"],
  "properties": {
    "clarificationNeeded": { "type": "boolean", "const": true },
    "reason": { "type": "string", "description": "为何需要澄清" },
    "recommendedEntity": {
      "type": "object",
      "properties": {
        "tableName": { "type": "string" },
        "entityNameEn": { "type": "string" },
        "comment": { "type": "string" }
      }
    },
    "recommendedFields": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "fieldKey": { "type": "string" },
          "comment": { "type": "string" },
          "required": { "type": "boolean" },
          "category": { "type": "string", "enum": ["business", "common"] }
        }
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "question": { "type": "string" },
          "missingType": { "type": "string" }
        }
      }
    }
  }
}
