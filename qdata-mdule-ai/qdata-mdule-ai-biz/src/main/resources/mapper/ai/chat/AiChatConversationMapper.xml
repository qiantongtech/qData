<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="tech.qiantong.qdata.module.ai.dal.mapper.chat.AiChatConversationMapper">

    <resultMap type="AiChatConversationDO" id="AiChatConversationResult">
        <result property="id"    column="ID"    />
        <result property="userId"    column="USER_ID"    />
        <result property="title"    column="TITLE"    />
        <result property="pinned"    column="PINNED"    />
        <result property="pinnedTime"    column="PINNED_TIME"    />
        <result property="datasourceId"    column="DATASOURCE_ID"    />
        <result property="factTableName"    column="FACT_TABLE_NAME"    />
        <result property="factTableComment"    column="FACT_TABLE_COMMENT"    />
        <result property="dimensionTable"    column="DIMENSION_TABLE"    />
        <result property="validFlag"    column="VALID_FLAG"    />
        <result property="delFlag"    column="DEL_FLAG"    />
        <result property="createBy"    column="CREATE_BY"    />
        <result property="creatorId"    column="CREATOR_ID"    />
        <result property="createTime"    column="CREATE_TIME"    />
        <result property="updateBy"    column="UPDATE_BY"    />
        <result property="updaterId"    column="UPDATER_ID"    />
        <result property="updateTime"    column="UPDATE_TIME"    />
        <result property="remark"    column="REMARK"    />
    </resultMap>

    <sql id="selectAiChatConversationVo">
        select ID, USER_ID, TITLE, PINNED, PINNED_TIME, DATASOURCE_ID, FACT_TABLE_NAME, FACT_TABLE_COMMENT, DIMENSION_TABLE, VALID_FLAG, DEL_FLAG, CREATE_BY, CREATOR_ID, CREATE_TIME, UPDATE_BY, UPDATER_ID, UPDATE_TIME, REMARK from AI_CHAT_CONVERSATION
    </sql>

    <select id="selectAiChatConversationList" parameterType="AiChatConversationDO" resultMap="AiChatConversationResult">
        <include refid="selectAiChatConversationVo"/>
        <where>
            <if test="userId != null "> and USER_ID = #{userId}</if>
            <if test="title != null  and title != ''"> and TITLE = #{title}</if>
            <if test="pinned != null  and pinned != ''"> and PINNED = #{pinned}</if>
            <if test="pinnedTime != null "> and PINNED_TIME = #{pinnedTime}</if>
            <if test="datasourceId != null "> and DATASOURCE_ID = #{datasourceId}</if>
            <if test="factTableName != null  and factTableName != ''"> and FACT_TABLE_NAME like concat('%', #{factTableName}, '%')</if>
            <if test="factTableComment != null  and factTableComment != ''"> and FACT_TABLE_COMMENT = #{factTableComment}</if>
            <if test="dimensionTable != null  and dimensionTable != ''"> and DIMENSION_TABLE = #{dimensionTable}</if>
            <if test="validFlag != null "> and VALID_FLAG = #{validFlag}</if>
            <if test="createTime != null "> and CREATE_TIME = #{createTime}</if>
        </where>
    </select>

    <select id="selectAiChatConversationById" parameterType="Long" resultMap="AiChatConversationResult">
        <include refid="selectAiChatConversationVo"/>
        where ID = #{id}
    </select>

    <insert id="insertAiChatConversation" parameterType="AiChatConversationDO">
        insert into AI_CHAT_CONVERSATION
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">ID,</if>
            <if test="userId != null">USER_ID,</if>
            <if test="title != null">TITLE,</if>
            <if test="pinned != null">PINNED,</if>
            <if test="pinnedTime != null">PINNED_TIME,</if>
            <if test="datasourceId != null">DATASOURCE_ID,</if>
            <if test="factTableName != null">FACT_TABLE_NAME,</if>
            <if test="factTableComment != null">FACT_TABLE_COMMENT,</if>
            <if test="dimensionTable != null">DIMENSION_TABLE,</if>
            <if test="validFlag != null">VALID_FLAG,</if>
            <if test="delFlag != null">DEL_FLAG,</if>
            <if test="createBy != null">CREATE_BY,</if>
            <if test="creatorId != null">CREATOR_ID,</if>
            <if test="createTime != null">CREATE_TIME,</if>
            <if test="updateBy != null">UPDATE_BY,</if>
            <if test="updaterId != null">UPDATER_ID,</if>
            <if test="updateTime != null">UPDATE_TIME,</if>
            <if test="remark != null">REMARK,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="userId != null">#{userId},</if>
            <if test="title != null">#{title},</if>
            <if test="pinned != null">#{pinned},</if>
            <if test="pinnedTime != null">#{pinnedTime},</if>
            <if test="datasourceId != null">#{datasourceId},</if>
            <if test="factTableName != null">#{factTableName},</if>
            <if test="factTableComment != null">#{factTableComment},</if>
            <if test="dimensionTable != null">#{dimensionTable},</if>
            <if test="validFlag != null">#{validFlag},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="creatorId != null">#{creatorId},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updaterId != null">#{updaterId},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateAiChatConversation" parameterType="AiChatConversationDO">
        update AI_CHAT_CONVERSATION
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">USER_ID = #{userId},</if>
            <if test="title != null">TITLE = #{title},</if>
            <if test="pinned != null">PINNED = #{pinned},</if>
            <if test="pinnedTime != null">PINNED_TIME = #{pinnedTime},</if>
            <if test="datasourceId != null">DATASOURCE_ID = #{datasourceId},</if>
            <if test="factTableName != null">FACT_TABLE_NAME = #{factTableName},</if>
            <if test="factTableComment != null">FACT_TABLE_COMMENT = #{factTableComment},</if>
            <if test="dimensionTable != null">DIMENSION_TABLE = #{dimensionTable},</if>
            <if test="validFlag != null">VALID_FLAG = #{validFlag},</if>
            <if test="delFlag != null">DEL_FLAG = #{delFlag},</if>
            <if test="createBy != null">CREATE_BY = #{createBy},</if>
            <if test="creatorId != null">CREATOR_ID = #{creatorId},</if>
            <if test="createTime != null">CREATE_TIME = #{createTime},</if>
            <if test="updateBy != null">UPDATE_BY = #{updateBy},</if>
            <if test="updaterId != null">UPDATER_ID = #{updaterId},</if>
            <if test="updateTime != null">UPDATE_TIME = #{updateTime},</if>
            <if test="remark != null">REMARK = #{remark},</if>
        </trim>
        where ID = #{id}
    </update>

    <delete id="deleteAiChatConversationById" parameterType="Long">
        delete from AI_CHAT_CONVERSATION where ID = #{id}
    </delete>

    <delete id="deleteAiChatConversationByIds" parameterType="String">
        delete from AI_CHAT_CONVERSATION where ID in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
