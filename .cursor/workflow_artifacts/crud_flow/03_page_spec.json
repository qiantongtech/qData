{
  "entityName": "数据源",
  "entityNameEn": "Datasource",
  "layoutNote": "纯列表页；表单弹窗含基础信息区与按 datasourceCategory/datasourceType 动态展示的连接配置区；类型与编码创建后不可修改；password/secretKey/token 掩码回显；删除前校验引用；连接测试记录 lastTestResult/lastTestTime/lastTestDuration。",
  "columns": [
    { "key": "id", "label": "编号", "type": "string", "width": 80 },
    { "key": "datasourceName", "label": "名称", "type": "string", "minWidth": 140, "required": true, "showOverflowTooltip": true, "validation": { "maxLength": 100, "message": "名称长度不能超过100个字符" } },
    { "key": "code", "label": "编码", "type": "string", "width": 120, "required": true, "showOverflowTooltip": true, "validation": { "maxLength": 64, "pattern": "^[A-Za-z0-9_\\-]+$", "message": "编码只能包含英文、数字、下划线和中划线" } },
    { "key": "description", "label": "描述", "type": "string", "minWidth": 160, "showOverflowTooltip": true, "validation": { "maxLength": 500, "message": "描述长度不能超过500个字符" } },
    { "key": "datasourceCategory", "label": "数据源大类", "type": "enum", "width": 120, "required": true, "enumOptions": [
      { "label": "关系型数据库", "value": "relationDb" },
      { "label": "大数据/数仓", "value": "bigData" },
      { "label": "文件/对象存储", "value": "fileStorage" },
      { "label": "接口类型", "value": "api" }
    ]},
    { "key": "datasourceType", "label": "数据源类型", "type": "enum", "width": 120, "required": true, "enumOptions": [
      { "label": "MySQL", "value": "MySQL" },
      { "label": "Oracle", "value": "Oracle" },
      { "label": "PostgreSQL", "value": "PostgreSQL" },
      { "label": "SQL Server", "value": "SQL Server" },
      { "label": "DB2", "value": "DB2" },
      { "label": "Doris", "value": "Doris" },
      { "label": "Hive", "value": "Hive" },
      { "label": "ClickHouse", "value": "ClickHouse" },
      { "label": "MaxCompute", "value": "MaxCompute" },
      { "label": "FTP", "value": "FTP" },
      { "label": "SFTP", "value": "SFTP" },
      { "label": "HDFS", "value": "HDFS" },
      { "label": "S3兼容", "value": "S3" },
      { "label": "Restful API", "value": "Restful API" }
    ]},
    { "key": "deptName", "label": "所属部门", "type": "string", "width": 120, "showOverflowTooltip": true },
    { "key": "owner", "label": "负责人", "type": "string", "width": 100, "validation": { "maxLength": 50, "message": "负责人长度不能超过50个字符" } },
    { "key": "envTag", "label": "环境标签", "type": "enum", "width": 90, "enumOptions": [
      { "label": "开发", "value": "dev" },
      { "label": "测试", "value": "test" },
      { "label": "生产", "value": "prod" }
    ]},
    { "key": "version", "label": "版本号", "type": "string", "width": 90, "validation": { "maxLength": 32, "message": "版本号长度不能超过32个字符" } },
    { "key": "status", "label": "状态", "type": "enum", "width": 90, "displayType": "tag", "enumOptions": [
      { "label": "启用", "value": "enabled" },
      { "label": "禁用", "value": "disabled" }
    ]},
    { "key": "lastTestResult", "label": "最近测试结果", "type": "enum", "width": 110, "displayType": "tag", "enumOptions": [
      { "label": "成功", "value": "success" },
      { "label": "失败", "value": "fail" },
      { "label": "未测试", "value": "untested" }
    ]},
    { "key": "lastTestTime", "label": "最近测试时间", "type": "datetime", "width": 160 },
    { "key": "lastTestDuration", "label": "最近测试耗时", "type": "string", "width": 100 },
    { "key": "host", "label": "主机地址", "type": "string", "formOnly": true, "validation": { "maxLength": 256, "message": "主机地址长度不能超过256个字符" } },
    { "key": "port", "label": "端口", "type": "number", "formOnly": true, "validation": { "min": 1, "max": 65535, "message": "端口号范围 1-65535" } },
    { "key": "dbName", "label": "数据库名/服务名", "type": "string", "formOnly": true, "validation": { "maxLength": 128, "message": "长度不能超过128个字符" } },
    { "key": "schema", "label": "Schema", "type": "string", "formOnly": true, "validation": { "maxLength": 64, "message": "Schema长度不能超过64个字符" } },
    { "key": "username", "label": "用户名", "type": "string", "formOnly": true, "validation": { "maxLength": 64, "message": "用户名长度不能超过64个字符" } },
    { "key": "password", "label": "密码", "type": "string", "formOnly": true, "sensitive": true, "validation": { "maxLength": 128, "message": "密码长度不能超过128个字符" } },
    { "key": "driverClass", "label": "驱动类", "type": "string", "formOnly": true, "validation": { "maxLength": 256, "message": "驱动类长度不能超过256个字符" } },
    { "key": "jdbcSuffix", "label": "JDBC URL 后缀", "type": "string", "formOnly": true, "validation": { "maxLength": 512, "message": "长度不能超过512个字符" } },
    { "key": "maxPoolSize", "label": "最大连接数", "type": "number", "formOnly": true, "validation": { "min": 1, "max": 1000, "message": "范围 1-1000" } },
    { "key": "connTimeout", "label": "连接超时时间", "type": "number", "formOnly": true, "validation": { "min": 0, "max": 300000, "message": "单位毫秒，范围 0-300000" } },
    { "key": "baseUrl", "label": "Base URL", "type": "string", "formOnly": true, "validation": { "maxLength": 512, "message": "Base URL长度不能超过512个字符" } },
    { "key": "rootPath", "label": "根路径", "type": "string", "formOnly": true, "validation": { "maxLength": 256, "message": "根路径长度不能超过256个字符" } },
    { "key": "authType", "label": "认证方式", "type": "enum", "formOnly": true, "enumOptions": [
      { "label": "AccessKey/SecretKey", "value": "aksk" },
      { "label": "Token", "value": "token" }
    ]},
    { "key": "accessKey", "label": "AccessKey", "type": "string", "formOnly": true, "validation": { "maxLength": 128, "message": "AccessKey长度不能超过128个字符" } },
    { "key": "secretKey", "label": "Secret Key", "type": "string", "formOnly": true, "sensitive": true, "validation": { "maxLength": 256, "message": "Secret Key长度不能超过256个字符" } },
    { "key": "token", "label": "Token", "type": "string", "formOnly": true, "sensitive": true, "validation": { "maxLength": 512, "message": "Token长度不能超过512个字符" } },
    { "key": "createBy", "label": "创建人", "type": "string", "width": 100 },
    { "key": "createTime", "label": "创建时间", "type": "datetime", "width": 160, "sortable": true }
  ],
  "searchFields": [
    { "key": "datasourceName", "label": "名称", "type": "string", "placeholder": "请输入名称" },
    { "key": "code", "label": "编码", "type": "string", "placeholder": "请输入编码" },
    { "key": "datasourceType", "label": "数据源类型", "type": "string", "placeholder": "请选择类型" },
    { "key": "status", "label": "状态", "type": "string", "placeholder": "请选择状态" },
    { "key": "envTag", "label": "环境标签", "type": "string", "placeholder": "请选择环境" },
    { "key": "deptId", "label": "所属部门", "type": "string", "placeholder": "请选择所属部门" }
  ],
  "actions": ["create", "update", "delete", "view"],
  "customActions": [
    { "key": "test", "label": "连接测试" },
    { "key": "toggleStatus", "label": "启用/禁用" }
  ],
  "actionPermissions": [
    { "action": "delete", "permissionKey": "dpp:datasource:remove", "description": "删除前须校验是否被数据资产、元数据采集任务、ETL开发任务、数据质量规则引用，存在引用则禁止删除并提示具体引用清单" }
  ],
  "pagination": { "pageSize": 10, "showSizeChanger": true, "pageSizeOptions": [10, 20, 50] },
  "tableConfig": { "stripe": true, "border": true, "showIndex": true, "showSelection": false }
}
