{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RequirementClarification",
  "description": "需求理解技能在信息缺失时的澄清输出，非完整 requirement_spec",
  "type": "object",
  "required": ["clarificationNeeded", "reason", "questions"],
  "properties": {
    "clarificationNeeded": { "type": "boolean", "const": true },
    "reason": { "type": "string", "description": "为何需要澄清" },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["question", "missingType", "suggestion"],
        "properties": {
          "question": { "type": "string" },
          "missingType": { "type": "string", "enum": ["business_object", "interaction_scope", "permission", "tech_boundary", "other"] },
          "suggestion": { "type": "string" }
        }
      }
    }
  }
}
