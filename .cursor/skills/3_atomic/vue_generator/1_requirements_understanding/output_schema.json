{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RequirementSpec",
  "description": "需求理解技能输出，供原型设计等下游技能消费",
  "type": "object",
  "required": [
    "featureList",
    "interactionIntents"
  ],
  "properties": {
    "featureList": {
      "type": "array",
      "description": "功能清单：拆解后的具体子功能点",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "功能唯一标识，如 F01、F02"
          },
          "name": {
            "type": "string",
            "description": "功能名称"
          },
          "description": {
            "type": "string",
            "description": "功能描述"
          },
          "priority": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ],
            "description": "优先级，可选"
          }
        }
      }
    },
    "businessRules": {
      "type": "array",
      "description": "业务逻辑规则：核心逻辑约束",
      "items": {
        "type": "object",
        "required": [
          "description",
          "constraintType"
        ],
        "properties": {
          "description": {
            "type": "string",
            "description": "规则描述"
          },
          "appliesTo": {
            "type": "string",
            "description": "适用功能或对象，如功能 id、实体名"
          },
          "constraintType": {
            "type": "string",
            "enum": [
              "permission",
              "required",
              "state",
              "validation",
              "other"
            ],
            "description": "约束类型：权限/必填/状态/校验/其他"
          }
        }
      }
    },
    "interactionIntents": {
      "type": "array",
      "description": "交互意图：用户在页面上要做的操作",
      "items": {
        "type": "object",
        "required": [
          "type",
          "description"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "query",
              "export",
              "import",
              "create",
              "update",
              "delete",
              "view",
              "associate",
              "other"
            ],
            "description": "意图类型：查询/导出/导入/新增/编辑/删除/查看/关联/其他"
          },
          "description": {
            "type": "string",
            "description": "简要说明"
          },
          "relatedFields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "涉及对象或字段，可选"
          }
        }
      }
    }
  }
}
