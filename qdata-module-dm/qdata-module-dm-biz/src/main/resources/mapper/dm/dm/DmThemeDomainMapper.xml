<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="tech.qiantong.qdata.module.dm.dal.mapper.dm.DmThemeDomainMapper">

    <resultMap type="DmThemeDomainDO" id="DmThemeDomainResult">
        <result property="id"    column="ID"    />
        <result property="code"    column="CODE"    />
        <result property="name"    column="NAME"    />
        <result property="engName"    column="ENG_NAME"    />
        <result property="parentId"    column="PARENT_ID"    />
        <result property="ownerUserId"    column="OWNER_USER_ID"    />
        <result property="dataLayerId"    column="DATA_LAYER_ID"    />
        <result property="description"    column="DESCRIPTION"    />
        <result property="validFlag"    column="VALID_FLAG"    />
        <result property="delFlag"    column="DEL_FLAG"    />
        <result property="createBy"    column="CREATE_BY"    />
        <result property="creatorId"    column="CREATOR_ID"    />
        <result property="createTime"    column="CREATE_TIME"    />
        <result property="updateBy"    column="UPDATE_BY"    />
        <result property="updaterId"    column="UPDATER_ID"    />
        <result property="updateTime"    column="UPDATE_TIME"    />
        <result property="remark"    column="REMARK"    />
    </resultMap>

    <sql id="selectDmThemeDomainVo">
        select ID, CODE, NAME, ENG_NAME, PARENT_ID, OWNER_USER_ID, DATA_LAYER_ID, DESCRIPTION, VALID_FLAG, DEL_FLAG, CREATE_BY, CREATOR_ID, CREATE_TIME, UPDATE_BY, UPDATER_ID, UPDATE_TIME, REMARK from DM_THEME_DOMAIN
    </sql>

    <select id="selectDmThemeDomainList" parameterType="DmThemeDomainDO" resultMap="DmThemeDomainResult">
        <include refid="selectDmThemeDomainVo"/>
        <where>
            <if test="code != null  and code != ''"> and CODE = #{code}</if>
            <if test="name != null  and name != ''"> and NAME like concat('%', #{name}, '%')</if>
            <if test="engName != null  and engName != ''"> and ENG_NAME like concat('%', #{engName}, '%')</if>
            <if test="parentId != null "> and PARENT_ID = #{parentId}</if>
            <if test="ownerUserId != null "> and OWNER_USER_ID = #{ownerUserId}</if>
            <if test="dataLayerId != null "> and DATA_LAYER_ID = #{dataLayerId}</if>
            <if test="description != null  and description != ''"> and DESCRIPTION like concat('%', #{description}, '%')</if>
            <if test="createTime != null "> and CREATE_TIME = #{createTime}</if>
        </where>
    </select>

    <select id="selectDmThemeDomainById" parameterType="Long" resultMap="DmThemeDomainResult">
        <include refid="selectDmThemeDomainVo"/>
        where ID = #{id}
    </select>

    <insert id="insertDmThemeDomain" parameterType="DmThemeDomainDO">
        insert into DM_THEME_DOMAIN
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">ID,</if>
            <if test="code != null">CODE,</if>
            <if test="name != null">NAME,</if>
            <if test="engName != null">ENG_NAME,</if>
            <if test="parentId != null">PARENT_ID,</if>
            <if test="ownerUserId != null">OWNER_USER_ID,</if>
            <if test="dataLayerId != null">DATA_LAYER_ID,</if>
            <if test="description != null">DESCRIPTION,</if>
            <if test="validFlag != null">VALID_FLAG,</if>
            <if test="delFlag != null">DEL_FLAG,</if>
            <if test="createBy != null">CREATE_BY,</if>
            <if test="creatorId != null">CREATOR_ID,</if>
            <if test="createTime != null">CREATE_TIME,</if>
            <if test="updateBy != null">UPDATE_BY,</if>
            <if test="updaterId != null">UPDATER_ID,</if>
            <if test="updateTime != null">UPDATE_TIME,</if>
            <if test="remark != null">REMARK,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="code != null">#{code},</if>
            <if test="name != null">#{name},</if>
            <if test="engName != null">#{engName},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="ownerUserId != null">#{ownerUserId},</if>
            <if test="dataLayerId != null">#{dataLayerId},</if>
            <if test="description != null">#{description},</if>
            <if test="validFlag != null">#{validFlag},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="creatorId != null">#{creatorId},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updaterId != null">#{updaterId},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateDmThemeDomain" parameterType="DmThemeDomainDO">
        update DM_THEME_DOMAIN
        <trim prefix="SET" suffixOverrides=",">
            <if test="code != null">CODE = #{code},</if>
            <if test="name != null">NAME = #{name},</if>
            <if test="engName != null">ENG_NAME = #{engName},</if>
            <if test="parentId != null">PARENT_ID = #{parentId},</if>
            <if test="ownerUserId != null">OWNER_USER_ID = #{ownerUserId},</if>
            <if test="dataLayerId != null">DATA_LAYER_ID = #{dataLayerId},</if>
            <if test="description != null">DESCRIPTION = #{description},</if>
            <if test="validFlag != null">VALID_FLAG = #{validFlag},</if>
            <if test="delFlag != null">DEL_FLAG = #{delFlag},</if>
            <if test="createBy != null">CREATE_BY = #{createBy},</if>
            <if test="creatorId != null">CREATOR_ID = #{creatorId},</if>
            <if test="createTime != null">CREATE_TIME = #{createTime},</if>
            <if test="updateBy != null">UPDATE_BY = #{updateBy},</if>
            <if test="updaterId != null">UPDATER_ID = #{updaterId},</if>
            <if test="updateTime != null">UPDATE_TIME = #{updateTime},</if>
            <if test="remark != null">REMARK = #{remark},</if>
        </trim>
        where ID = #{id}
    </update>

    <delete id="deleteDmThemeDomainById" parameterType="Long">
        delete from DM_THEME_DOMAIN where ID = #{id}
    </delete>

    <delete id="deleteDmThemeDomainByIds" parameterType="String">
        delete from DM_THEME_DOMAIN where ID in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
