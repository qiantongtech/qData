{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PrototypeSpec",
  "description": "原型设计技能输出：仅页面结构与语义，不含与后端对齐的命名。对象名、字段 key、权限标识由下一技能「数据模型定义」产出。",
  "type": "object",
  "required": ["entityLabel", "columns"],
  "properties": {
    "entityLabel": {
      "type": "string",
      "description": "实体中文名称（显示用），英文名与 API 资源名由数据模型定义技能确定",
      "examples": ["员工", "订单", "商品"]
    },
    "columns": {
      "type": "array",
      "description": "表格列/表单字段：仅 label（中文）、type、required 等语义，不含 key",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "type"],
        "properties": {
          "label": {
            "type": "string",
            "description": "字段显示名称（中文）"
          },
          "type": {
            "type": "string",
            "enum": ["string", "number", "date", "datetime", "boolean", "enum"],
            "description": "字段数据类型"
          },
          "required": {
            "type": "boolean",
            "description": "是否必填（用于表单）",
            "default": false
          },
          "enumOptions": {
            "type": "array",
            "description": "枚举选项（当 type 为 enum 时），仅 label；value 由数据模型定义确定",
            "items": {
              "type": "object",
              "properties": {
                "label": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "searchFields": {
      "type": "array",
      "description": "参与搜索的字段：仅 label、type，不含 key",
      "items": {
        "type": "object",
        "required": ["label", "type"],
        "properties": {
          "label": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["string", "number", "date", "datetime"]
          },
          "placeholder": { "type": "string" }
        }
      }
    },
    "actions": {
      "type": "array",
      "description": "页面操作类型，不含权限标识（权限标识由数据模型定义技能产出）",
      "items": {
        "type": "string",
        "enum": ["create", "update", "delete", "view", "export", "import"]
      }
    },
    "actionPermissions": {
      "type": "array",
      "description": "仅描述「哪些操作有权限约束」，不产出具体权限码",
      "items": {
        "type": "object",
        "properties": {
          "action": { "type": "string", "enum": ["create", "update", "delete", "view", "export", "import"] },
          "description": { "type": "string", "description": "如：仅管理员可删" }
        }
      }
    },
    "pagination": {
      "type": "object",
      "properties": {
        "pageSize": { "type": "number", "minimum": 1 },
        "showSizeChanger": { "type": "boolean" },
        "pageSizeOptions": { "type": "array", "items": { "type": "number" } }
      }
    },
    "tableConfig": {
      "type": "object",
      "properties": {
        "stripe": { "type": "boolean" },
        "border": { "type": "boolean" },
        "showIndex": { "type": "boolean" },
        "showSelection": { "type": "boolean" }
      }
    }
  }
}
